{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:product-wiki:schema:wiki-unit",
  "title": "Product Wiki wiki unit",
  "type": "object",
  "required": ["id", "type", "status", "updated"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*$"
    },
    "type": {
      "type": "string",
      "enum": [
        "actor",
        "job",
        "story",
        "acceptance-criterion",
        "rule",
        "journey",
        "capability",
        "outcome",
        "non-goal",
        "assumption",
        "glossary",
        "decision",
        "design-system",
        "overview",
        "index",
        "log"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "proposed", "active", "superseded", "rejected"]
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
